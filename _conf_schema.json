{
  "llm_mode": {
    "description": "LLM 模式配置",
    "type": "object",
    "hint": "启用后，所有掷骰结果将通过 LLM 进行美化输出；关闭时使用普通模板输出",
    "items": {
      "enabled": {
        "description": "是否启用 LLM 美化模式",
        "type": "bool",
        "default": false
      },
      "model": {
        "description": "使用的模型 ID（留空则使用当前对话默认模型）",
        "type": "string",
        "hint": "例如：gpt-4o、claude-3-5-sonnet，留空使用主对话模型",
        "default": ""
      },
      "system_prompt": {
        "description": "LLM 美化输出的系统提示词",
        "type": "text",
        "hint": "骰子原始结果文本会作为用户消息发送给 LLM，此处填写系统提示词",
        "default": "你是一个跑团骰娘，风格活泼可爱。请用简短生动的语言（不超过60字）描述以下掷骰结果，可以加入一点点角色扮演风格，但必须保留所有数字和判定结论。"
      }
    }
  },
  "output": {
    "description": "输出配置 - 自定义所有输出文本",
    "type": "object",
    "hint": "可自定义所有掷骰、判定和系统输出文本，使用 {变量名} 作为占位符",
    "items": {
      "skill_check": {
        "description": "技能判定输出",
        "type": "object",
        "items": {
          "normal": {
            "description": "普通技能判定 (变量: name, skill_name, roll_result, skill_value, result)",
            "type": "text",
            "default": "<{name}> 的【{skill_name}】检定: {roll_result}/{skill_value} → {result}"
          },
          "penalty": {
            "description": "惩罚骰 (变量: name, new_tens_digits, final_y, skill_value, result)",
            "type": "text",
            "default": "<{name}> 惩罚骰: {new_tens_digits} → 最终结果: {final_y}/{skill_value} → {result}"
          },
          "bonus": {
            "description": "奖励骰 (变量: name, new_tens_digits, final_y, skill_value, result)",
            "type": "text",
            "default": "<{name}> 奖励骰: {new_tens_digits} → 最终结果: {final_y}/{skill_value} → {result}"
          },
          "error": {
            "description": "技能判定错误",
            "type": "object",
            "items": {
              "normal": {
                "description": "普通判定错误",
                "type": "text",
                "default": "技能 {skill_name} 未找到"
              },
              "penalty": {
                "description": "惩罚骰参数错误",
                "type": "text",
                "default": "惩罚骰参数错误: 技能 {skill_name}"
              },
              "bonus": {
                "description": "奖励骰参数错误",
                "type": "text",
                "default": "奖励骰参数错误: 技能 {skill_name}"
              }
            }
          }
        }
      },
      "rp": {
        "description": "运势输出",
        "type": "object",
        "items": {
          "today": {
            "description": "运势查询 (变量: rp)",
            "type": "text",
            "default": "今日的运势是: {rp}/100 哦~"
          }
        }
      },
      "fireball": {
        "description": "火球术输出",
        "type": "object",
        "items": {
          "result": {
            "description": "火球术伤害 (变量: ring, breakdown, total)",
            "type": "text",
            "default": "{ring} 环火球术伤害: {breakdown} = {total}"
