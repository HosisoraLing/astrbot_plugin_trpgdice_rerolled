            }
          },
          "update": {
            "description": "更新人物卡",
            "type": "object",
            "items": {
              "no_active": {
                "description": "未选择人物卡",
                "type": "text",
                "default": "未选择人物卡 (.pc change)"
              },
              "error_format": {
                "description": "格式错误",
                "type": "text",
                "default": "格式错误，示例: 力量+1"
              },
              "success": {
                "description": "更新成功 (变量: attr, old, new)",
