        }
      },
      "coc_roll": {
        "description": "COC判定结果",
        "type": "object",
        "items": {
          "set_rule": {
            "description": "设置规则提示 (变量: rule)",
            "type": "text",
            "default": "收到！接下来大成功/大失败将会按照{rule}规则进行哦~"
          },
          "results": {
            "description": "判定结果文本",
            "type": "object",
            "items": {
              "great_success": {
                "description": "大成功",
                "type": "text",
                "default": "大成功！！！"
              },
              "extreme_success": {
                "description": "极难成功",
                "type": "text",
                "default": "极难成功！！"
