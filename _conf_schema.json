              "success": {
                "description": "成功",
                "type": "text",
                "default": "成功"
              },
              "great_failure": {
                "description": "大失败",
                "type": "text",
                "default": "大失败！！！"
              },
              "failure": {
                "description": "失败",
                "type": "text",
                "default": "失败"
              },
              "error": {
                "description": "错误",
                "type": "text",
                "default": "错误: {error}"
              },
              "reset": {
                "description": "规则重置提示",
                "type": "text",
                "default": "判定规则已重置为 {rule} ~"
              }
            }
          }
        }
      },
      "pc": {
