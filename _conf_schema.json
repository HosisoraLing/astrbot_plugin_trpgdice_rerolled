          "delete": {
            "description": "删除人物卡",
            "type": "object",
            "items": {
              "fail": {
                "description": "删除失败 (变量: name)",
                "type": "text",
                "default": "人物卡 [{name}] 不存在"
              },
              "success": {
                "description": "删除成功 (变量: name)",
                "type": "text",
                "default": "人物卡 [{name}] 已删除"
              }
            }
          },
          "grow": {
            "description": "技能成长",
            "type": "object",
            "items": {
              "success": {
                "description": "成长成功 (变量: skill_name, skill_value, new_value, en_value)",
